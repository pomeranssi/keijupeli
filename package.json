{
  "name": "keijupeli",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "homepage": "https://keijupeli.pomeranssi.fi/",
  "scripts": {
    "watch-client": "vite",
    "watch-server": "DEBUG='server*' tsx watch --tsconfig tsconfig.server.json src/server/keijupeliServer.ts",
    "build-client": "vite build",
    "build-server": "tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json && node -e \"require('fs').writeFileSync('build-server/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\" && node -e \"require('fs').writeFileSync('build-server/yarn.lock', '')\"",
    "preview-client": "vite preview",
    "clean": "rm -rf build/ dist/ build-server/",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint-fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test-watch": "vitest",
    "migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "migrate-make": "knex --knexfile knexfile.cjs migrate:make",
    "migrate-rollback": "knex --knexfile knexfile.cjs migrate:rollback"
  },
  "dependencies": {
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "history": "5.3.0",
    "knex": "3.2.9",
    "luxon": "3.7.2",
    "multer": "2.1.1",
    "pg": "8.20.0",
    "pg-promise": "12.6.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.1",
    "sharp": "0.34.5",
    "styled-components": "6.4.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/debug": "4.1.13",
    "@types/express": "5.0.6",
    "@types/luxon": "3.7.1",
    "@types/multer": "2.1.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "tsc-alias": "^1.8.16",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
